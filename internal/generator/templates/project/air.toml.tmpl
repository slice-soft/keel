root    = "."
tmp_dir = "tmp"

[build]
  cmd           = "go build -o ./tmp/main ./cmd"
  bin           = "./tmp/main"
  delay         = 1000
  exclude_dir   = ["assets", "tmp", "vendor", "docs"]
  include_ext   = ["go", "toml", "env", "properties"]
  exclude_regex = ["_test\\.go"]

[log]
  time = true

[color]
  main    = "magenta"
  watcher = "cyan"
  build   = "yellow"
  runner  = "green"

[misc]
  clean_on_exit = true
