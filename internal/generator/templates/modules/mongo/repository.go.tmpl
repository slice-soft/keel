	"strings"

	"github.com/slice-soft/ss-keel-core/contracts"
	"github.com/slice-soft/ss-keel-core/core"
	"github.com/slice-soft/ss-keel-core/core/httpx"
	"github.com/slice-soft/ss-keel-core/logger"
	"github.com/slice-soft/ss-keel-mongo/mongo"
)

type {{.PascalName}}RepositoryContract interface {
	contracts.Repository[{{.PascalName}}Entity, string, httpx.PageQuery, httpx.Page[{{.PascalName}}Entity]]
}

// {{.PascalName}}MongoDocument is the internal BSON representation stored in MongoDB.
// It uses string (_id) which maps to the UUID generated by EntityBase.OnCreate.
type {{.PascalName}}MongoDocument struct {
	ID        string `bson:"_id,omitempty"`
	CreatedAt int64  `bson:"created_at"`
	UpdatedAt int64  `bson:"updated_at"`
	Name      string `bson:"name"`
}

type {{.PascalName}}Repository struct {
	repo *mongo.MongoRepository[{{.PascalName}}MongoDocument, string]
	log *logger.Logger
}

var _ {{.PascalName}}RepositoryContract = (*{{.PascalName}}Repository)(nil)

func New{{.PascalName}}Repository(log *logger.Logger, client *mongo.Client) *{{.PascalName}}Repository {
	return &{{.PascalName}}Repository{
		repo: mongo.NewRepository[{{.PascalName}}MongoDocument, string](client, "{{.SnakeName}}"),
		log:  log,
	}
}

func (r *{{.PascalName}}Repository) FindByID(ctx context.Context, id string) (*{{.PascalName}}Entity, error) {
	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return nil, err
	}

	document, err := r.repo.FindByID(ctx, normalizedID)
	if err != nil {
		return nil, err
	}
	if document == nil {
		return nil, nil
	}

	entity := to{{.PascalName}}Entity(*document)
	return &entity, nil
}

func (r *{{.PascalName}}Repository) FindAll(ctx context.Context, q httpx.PageQuery) (httpx.Page[{{.PascalName}}Entity], error) {
	page, err := r.repo.FindAll(ctx, q)
	if err != nil {
		return httpx.Page[{{.PascalName}}Entity]{}, err
	}

	items := make([]{{.PascalName}}Entity, 0, len(page.Data))
	for _, document := range page.Data {
		items = append(items, to{{.PascalName}}Entity(document))
	}

	return httpx.NewPage(items, page.Total, page.Page, page.Limit), nil
}

func (r *{{.PascalName}}Repository) Create(ctx context.Context, entity *{{.PascalName}}Entity) error {
	entity.OnCreate()

	document := to{{.PascalName}}MongoDocument(entity)
	if err := r.repo.Create(ctx, &document); err != nil {
		return err
	}

	entity.ID = document.ID
	return nil
}

// Update replaces all fields of the document (HTTP PUT semantics).
func (r *{{.PascalName}}Repository) Update(ctx context.Context, id string, entity *{{.PascalName}}Entity) error {
	entity.OnUpdate()

	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return err
	}

	document := to{{.PascalName}}MongoDocument(entity)
	document.ID = normalizedID

	if err := r.repo.Update(ctx, normalizedID, &document); err != nil {
		return err
	}

	entity.ID = document.ID
	return nil
}

// Patch applies a partial update — only the fields present in entity are written (HTTP PATCH semantics).
// The service merges the request fields into the existing entity before calling Patch.
func (r *{{.PascalName}}Repository) Patch(ctx context.Context, id string, entity *{{.PascalName}}Entity) error {
	entity.OnUpdate()

	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return err
	}

	document := to{{.PascalName}}MongoDocument(entity)
	return r.repo.Patch(ctx, normalizedID, &document)
}

func (r *{{.PascalName}}Repository) Delete(ctx context.Context, id string) error {
	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return err
	}
	return r.repo.Delete(ctx, normalizedID)
}

func to{{.PascalName}}MongoDocument(entity *{{.PascalName}}Entity) {{.PascalName}}MongoDocument {
	return {{.PascalName}}MongoDocument{
		ID:        entity.ID,
		CreatedAt: entity.CreatedAt,
		UpdatedAt: entity.UpdatedAt,
		Name:      entity.Name,
	}
}

func to{{.PascalName}}Entity(document {{.PascalName}}MongoDocument) {{.PascalName}}Entity {
	return {{.PascalName}}Entity{
		EntityBase: mongo.EntityBase{
			ID:        document.ID,
			CreatedAt: document.CreatedAt,
			UpdatedAt: document.UpdatedAt,
		},
		Name: document.Name,
	}
}

// normalize{{.PascalName}}ID trims whitespace and validates that the ID is non-empty.
// Keel uses UUID strings as the only ID strategy — no ObjectID conversion needed.
func normalize{{.PascalName}}ID(id string) (string, error) {
	trimmedID := strings.TrimSpace(id)
	if trimmedID == "" {
		return "", core.BadRequest("invalid {{.KebabName}} id")
	}
	return trimmedID, nil
}
