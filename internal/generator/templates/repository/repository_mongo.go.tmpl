func (r *{{.PascalName}}Repository) FindByID(ctx context.Context, id string) (*{{.PascalName}}Entity, error) {
	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return nil, err
	}

	document, err := r.repo.FindByID(ctx, normalizedID)
	if err != nil {
		return nil, err
	}
	if document == nil {
		return nil, nil
	}

	entity := to{{.PascalName}}Entity(*document)
	return &entity, nil
}

func (r *{{.PascalName}}Repository) FindAll(ctx context.Context, q httpx.PageQuery) (httpx.Page[{{.PascalName}}Entity], error) {
	page, err := r.repo.FindAll(ctx, q)
	if err != nil {
		return httpx.Page[{{.PascalName}}Entity]{}, err
	}

	items := make([]{{.PascalName}}Entity, 0, len(page.Data))
	for _, document := range page.Data {
		items = append(items, to{{.PascalName}}Entity(document))
	}

	return httpx.NewPage(items, page.Total, page.Page, page.Limit), nil
}

func (r *{{.PascalName}}Repository) Create(ctx context.Context, entity *{{.PascalName}}Entity) error {
	document, err := to{{.PascalName}}MongoDocument(entity)
	if err != nil {
		return err
	}
	if document.ID.IsZero() {
		document.ID = primitive.NewObjectID()
	}

	if err := r.repo.Create(ctx, &document); err != nil {
		return err
	}

	entity.ID = document.ID.Hex()
	return nil
}

func (r *{{.PascalName}}Repository) Update(ctx context.Context, id string, entity *{{.PascalName}}Entity) error {
	normalizedID, err := normalize{{.PascalName}}ID(id)
