}

func (r *{{.PascalName}}Repository) Delete(ctx context.Context, id string) error {
	normalizedID, err := normalize{{.PascalName}}ID(id)
	if err != nil {
		return err
	}
	return r.repo.Delete(ctx, normalizedID)
}

func to{{.PascalName}}MongoDocument(entity *{{.PascalName}}Entity) ({{.PascalName}}MongoDocument, error) {
	if entity == nil {
		return {{.PascalName}}MongoDocument{}, core.BadRequest("{{.KebabName}} entity is required")
	}

	document := {{.PascalName}}MongoDocument{
		Name: entity.Name,
	}

	if trimmedID := strings.TrimSpace(entity.ID); trimmedID != "" {
		objectID, err := primitive.ObjectIDFromHex(trimmedID)
		if err != nil {
			return {{.PascalName}}MongoDocument{}, core.BadRequest("invalid {{.KebabName}} id")
		}
		document.ID = objectID
	}

	return document, nil
}

func to{{.PascalName}}Entity(document {{.PascalName}}MongoDocument) {{.PascalName}}Entity {
	return {{.PascalName}}Entity{
		ID:   document.ID.Hex(),
		Name: document.Name,
	}
}

func normalize{{.PascalName}}ID(id string) (string, error) {
	trimmedID := strings.TrimSpace(id)
	if trimmedID == "" {
		return "", core.BadRequest("invalid {{.KebabName}} id")
	}

	if _, err := primitive.ObjectIDFromHex(trimmedID); err != nil {
		return "", core.BadRequest("invalid {{.KebabName}} id")
	}

	return trimmedID, nil
}
